{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile photo URL" },
        "isPremium": { "type": "boolean", "description": "Whether the user has paid to remove ads" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "Note": {
      "title": "Note",
      "description": "A user's note",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique note ID" },
        "userId": { "type": "string", "description": "Owner's user ID" },
        "title": { "type": "string", "description": "Note title" },
        "content": { "type": "string", "description": "Raw text content" },
        "markup": { "type": "string", "description": "AI-generated or formatted markup" },
        "embeddings": { "type": "array", "items": { "type": "number" }, "description": "Vector embeddings for semantic search" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Note tags" },
        "isVoiceNote": { "type": "boolean", "description": "Whether this note was created via voice" },
        "audioUrl": { "type": "string", "description": "URL to the audio file if applicable" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["userId", "content", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes"
    }
  }
}
